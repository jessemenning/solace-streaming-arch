# ── Fleet Operations AI — environment variables ───────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# LiteLLM proxy endpoint — leave blank (or comment out) to call Anthropic directly.
# Uncomment and set if routing through a LiteLLM gateway.
# LITELLM_BASE_URL=https://your-litellm-proxy/v1

# Optional: RisingWave connection (defaults shown)
RW_HOST=localhost
RW_PORT=4566

# Solace Platform connection — used by the solace+ CLI and Try Me UI
# Host uses the mapped host port (55554); containers override SOLACE_HOST to tcp://solace:55555
SOLACE_HOST=tcp://localhost:55554
SOLACE_VPN=streaming-poc
SOLACE_USER=streaming-user
SOLACE_PASSWORD=default

# Solace Cloud API token — used by generate_mvs.py to read Event Portal catalog
# Generate at: https://console.solace.cloud/api-tokens
SOLACE_CLOUD_TOKEN=

# Generator tuning — override defaults for lower/higher data volume
NUM_VEHICLES=10         # number of simulated vehicles (default: 10)
TELEMETRY_INTERVAL=5.0  # seconds between combined telemetry messages per vehicle (default: 5.0)
