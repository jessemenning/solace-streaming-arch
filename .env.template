# ── Fleet Operations AI — environment variables ───────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: LiteLLM proxy endpoint
# Set this to route Claude calls through a LiteLLM gateway instead of direct API.
# Leave blank to call the Anthropic API directly.
LITELLM_BASE_URL=https://your-litellm-proxy/v1

# Optional: RisingWave connection (defaults shown)
RW_HOST=localhost
RW_PORT=4566

# Solace Cloud API token — used by generate_mvs.py to read Event Portal catalog
# Generate at: https://console.solace.cloud/api-tokens
SOLACE_CLOUD_TOKEN=

# Generator tuning — override defaults for lower/higher data volume
NUM_VEHICLES=10         # number of simulated vehicles (default: 10)
TELEMETRY_INTERVAL=5.0  # seconds between combined telemetry messages per vehicle (default: 5.0)
